{
  "name": "imagine-whiteboard",
  "version": "1.0.0",
  "description": "A multifaceted whiteboard application",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "icons:gen": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "immer": "^10.1.1",
    "perfect-freehand": "^1.2.2",
    "roughjs": "^4.6.6",
    "uuid": "^10.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.77.6",
    "sharp": "^0.34.5",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.imagine.whiteboard",
    "productName": "Imagine Whiteboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": "nsis"
    },
    "mac": {
      "icon": "resources/icon.png",
      "target": "dmg"
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": "AppImage"
    }
  }
}
